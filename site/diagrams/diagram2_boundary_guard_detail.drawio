<mxfile host="Electron" version="29.6.6">
  <diagram id="dam-stage-dag" name="Guard Stage DAG">
    <mxGraphModel grid="1" gridSize="10" pageWidth="900" pageHeight="860" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="DAM — Guard Stage DAG (per cycle)" style="text;html=1;fontSize=18;fontStyle=1;fontColor=#E2E8F0;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="18" width="700" height="32" as="geometry" />
        </mxCell>

        <!-- Inputs -->
        <mxCell id="inputs" value="Observation snapshot  +  ActionProposal&#xa;(from ObservationBus &amp; PolicyAdapter, via InjectionPool)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#475569;fontColor=#94A3B8;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="200" y="70" width="500" height="60" as="geometry" />
        </mxCell>

        <!-- Stage 1: L0 OOD -->
        <mxCell id="stage1_lbl" value="Stage 1" style="text;html=1;fontSize=11;fontColor=#64748B;align=left;" vertex="1" parent="1">
          <mxGeometry x="80" y="175" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="l0" value="L0  OOD Guard&#xa;Out-of-Distribution check — gates entire pipeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E3A8A;strokeColor=#60A5FA;fontColor=#DBEAFE;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="170" width="500" height="70" as="geometry" />
        </mxCell>
        <mxCell id="l0_reject_lbl" value="REJECT → short-circuit" style="text;html=1;fontSize=11;fontColor=#F87171;align=left;" vertex="1" parent="1">
          <mxGeometry x="720" y="195" width="160" height="20" as="geometry" />
        </mxCell>

        <!-- Stage 2: parallel L2 + L1 -->
        <mxCell id="stage2_lbl" value="Stage 2" style="text;html=1;fontSize=11;fontColor=#64748B;align=left;" vertex="1" parent="1">
          <mxGeometry x="80" y="295" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="stage2_bg" value="" style="rounded=1;fillColor=#1E293B;strokeColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="160" y="288" width="580" height="110" as="geometry" />
        </mxCell>
        <mxCell id="stage2_parallel_lbl" value="parallel" style="text;html=1;fontSize=11;fontColor=#64748B;align=center;" vertex="1" parent="1">
          <mxGeometry x="380" y="292" width="140" height="18" as="geometry" />
        </mxCell>
        <mxCell id="l2" value="L2  Motion Guard&#xa;joint limits · velocity · workspace" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4338CA;strokeColor=#818CF8;fontColor=#E0E7FF;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="175" y="315" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="l1" value="L1  Sim Preflight  ⟨shadow thread⟩&#xa;lookahead via SimulatorAdapter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C2410C;strokeColor=#FB923C;fontColor=#FFEDD5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="475" y="315" width="250" height="70" as="geometry" />
        </mxCell>

        <!-- Stage 3: L3 -->
        <mxCell id="stage3_lbl" value="Stage 3" style="text;html=1;fontSize=11;fontColor=#64748B;align=left;" vertex="1" parent="1">
          <mxGeometry x="80" y="455" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="l3" value="L3  Execution Guard&#xa;real-time monitoring · per-joint enforcement" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6B21A8;strokeColor=#C084FC;fontColor=#F3E8FF;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="200" y="450" width="500" height="70" as="geometry" />
        </mxCell>

        <!-- DecisionAggregator -->
        <mxCell id="decision_agg" value="DecisionAggregator&#xa;PASS  ·  CLAMP  ·  REJECT  ·  FAULT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#312E81;strokeColor=#818CF8;fontColor=#C7D2FE;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="578" width="500" height="66" as="geometry" />
        </mxCell>

        <!-- Outcomes -->
        <mxCell id="pass_node" value="ValidatedAction&#xa;(possibly clamped)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#14532D;strokeColor=#4ADE80;fontColor=#F0FDF4;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="120" y="710" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="reject_node" value="FallbackRegistry&#xa;hold · e-stop · custom" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7F1D1D;strokeColor=#F87171;fontColor=#FEE2E2;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="570" y="710" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="action_bus" value="ActionBus  [Rust]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#92400E;strokeColor=#F59E0B;fontColor=#FEF3C7;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="810" width="280" height="50" as="geometry" />
        </mxCell>

        <!-- ── ARROWS ── -->
        <!-- inputs → l0 -->
        <mxCell id="e1" edge="1" source="inputs" target="l0" style="endArrow=block;endFill=1;strokeColor=#475569;strokeWidth=2;" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- l0 PASS → stage2 -->
        <mxCell id="e2" edge="1" source="l0" target="stage2_bg" style="endArrow=block;endFill=1;strokeColor=#4ADE80;strokeWidth=3;" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2_lbl" value="PASS" style="edgeLabel;fontSize=11;fontColor=#4ADE80;fontStyle=1;" vertex="1" connectable="0" parent="e2">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- l0 REJECT → reject_node (short-circuit) -->
        <mxCell id="e_l0_reject" edge="1" source="l0" target="reject_node" style="endArrow=block;endFill=1;strokeColor=#F87171;strokeWidth=2;dashed=1;" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="820" y="205" />
              <mxPoint x="820" y="745" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- stage2 → l3 -->
        <mxCell id="e3" edge="1" source="stage2_bg" target="l3" style="endArrow=block;endFill=1;strokeColor=#475569;strokeWidth=2;" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- l3 → decisionAgg -->
        <mxCell id="e4" edge="1" source="l3" target="decision_agg" style="endArrow=block;endFill=1;strokeColor=#475569;strokeWidth=2;" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- decisionAgg → pass_node -->
        <mxCell id="e5" edge="1" source="decision_agg" target="pass_node" style="endArrow=block;endFill=1;strokeColor=#4ADE80;strokeWidth=3;" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5_lbl" value="PASS / CLAMP" style="edgeLabel;fontSize=11;fontColor=#4ADE80;fontStyle=1;" vertex="1" connectable="0" parent="e5">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- decisionAgg → reject_node -->
        <mxCell id="e6" edge="1" source="decision_agg" target="reject_node" style="endArrow=block;endFill=1;strokeColor=#F87171;strokeWidth=3;" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6_lbl" value="REJECT / FAULT" style="edgeLabel;fontSize=11;fontColor=#F87171;fontStyle=1;" vertex="1" connectable="0" parent="e6">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- pass_node → action_bus -->
        <mxCell id="e7" edge="1" source="pass_node" target="action_bus" style="endArrow=block;endFill=1;strokeColor=#4ADE80;strokeWidth=2;" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- reject_node → action_bus (after fallback executes safe action) -->
        <mxCell id="e8" edge="1" source="reject_node" target="action_bus" style="endArrow=block;endFill=1;strokeColor=#F87171;strokeWidth=2;dashed=1;" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8_lbl" value="safe fallback action" style="edgeLabel;fontSize=11;fontColor=#F87171;" vertex="1" connectable="0" parent="e8">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- Fault note -->
        <mxCell id="fault_note" value="Any exception in guard.check() → GuardResult.FAULT → treated as REJECT  (fail-to-reject)" style="text;html=1;fontSize=11;fontColor=#94A3B8;align=center;" vertex="1" parent="1">
          <mxGeometry x="150" y="800" width="560" height="20" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
